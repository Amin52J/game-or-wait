NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Deployed web app URL (used by desktop app for OAuth callback)
# NEXT_PUBLIC_APP_URL=https://www.gameorwait.com

# Mixpanel (server-side via /api/analytics/track — not exposed to the browser)
# MIXPANEL_TOKEN=your-mixpanel-project-token
# MIXPANEL_API_HOST=https://api-eu.mixpanel.com  # optional, EU data residency

# Steam integration (set as Supabase Edge Function secrets)
# STEAM_API_KEY=your-steam-web-api-key
